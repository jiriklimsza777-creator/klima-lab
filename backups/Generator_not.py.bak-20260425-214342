def _split_theme(theme):
    parts = [part.strip() for part in theme.split("|")]
    if len(parts) == 2:
        return parts[0], parts[1]
    return "", theme


def _get_producer_profile(producer):
    profile = dict(DEFAULT_PROFILE)
    profile.update(PRODUCER_PROFILES.get(producer, {}))
    return profile


